# ============================================================
# BookBot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Two components:
#   1. Render (main.py)        — thin Messenger webhook proxy
#   2. HF Space (processor.py) — AI processor + booking engine
# ============================================================

# ── Facebook Messenger (Render / main.py) ────────────────────────────────────
PAGE_ACCESS_TOKEN=EAAxxxYourPageAccessTokenHere
APP_SECRET=your_facebook_app_secret_here        # HMAC signature verification
VERIFY_TOKEN=your_custom_webhook_verify_token   # must match FB webhook config

# ── HuggingFace Space URL (Render / main.py) ─────────────────────────────────
HF_PROCESSOR_URL=https://your-username-bookhotel.hf.space

# ── Database — Supabase direct PostgreSQL (HF Space / processor.py) ──────────
# Use the Session-mode pooler URL from Supabase Dashboard > Connect > Session.
# Note: percent-encode special chars in password, e.g. @ → %40
DATABASE_URL=postgresql://postgres.xxxx:YourPassword@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Upstash Redis (HF Space secrets — HTTP REST, no TCP needed) ───────────────
# Get from Upstash Console → your database → REST API tab
UPSTASH_REDIS_URL=https://xxxx.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_rest_token

# ── HF token for CI/CD deployment ────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_SPACE_ID=your-username/bookhotel

# ── Groq LLM (optional — concierge/FAQ answers) ───────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (optional — payment processing) ────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ── Render service ID (for deploy webhook, optional) ─────────────────────────
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxx

# ── SendGrid / Email (optional) ───────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=BookBot

# ── Handoff / Agent Notification (optional) ──────────────────────────────────
HANDOFF_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxx

# ── Analytics (optional) ─────────────────────────────────────────────────────
ANALYTICS_ADMIN_KEY=your_super_secret_admin_key

# ClickHouse / Kafka connection (if using analytics_service)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=hotel_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Celery / Task Queue ──────────────────────────────────────
# Used by tasks/celery_app.py for scheduled jobs
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Tesseract OCR (optional, for passport scanning) ──────────
# Path to Tesseract binary (leave blank for system default)
TESSERACT_CMD=

# ── Misc ─────────────────────────────────────────────────────
# Set to "production" in production
APP_ENV=development

# HuggingFace model cache directory (set to persistent volume on HF Spaces)
# HF_HOME=/data/.huggingface

# Whisper model size: tiny | base | small (base recommended for CPU tier)
WHISPER_MODEL_SIZE=base

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
